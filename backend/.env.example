# ------------------------------------------------------------------------------
# LERNO BACKEND - ENVIRONMENT VARIABLES
# ------------------------------------------------------------------------------

# API Configuration
PROJECT_NAME="Lerno API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="super-secret-key-change-this-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# PostgreSQL Database
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="lerno"
POSTGRES_PORT=5432
# SQLALCHEMY_DATABASE_URI will be dynamically generated by settings, 
# but you can override it entirely:
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/lerno"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Celery
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# CORS
# e.g. '["http://localhost:3000", "http://localhost:8080"]'
BACKEND_CORS_ORIGINS='["*"]'
